{
  "name": "@vvi/rollup-external",
  "version": "1.2.2",
  "type": "module",
  "private": true,
  "scripts": {
    "b": "rollup --config rollup.config.js && tsc -p tsconfig.types.json",
    "build": "jja cls rm dist && pnpm run b && pnpm run clean:package",
    "clean:package": "node scripts/clean-package-json.js",
    "diff": "jja pkg --diff=淘宝",
    "prepublishOnly": "pjj",
    "push": "gvv",
    "push:version": "gvv",
    "test": "jja rm .eg && rollup --config rollup.config.eg.js && node .eg/index.mjs",
    "vjj": "vjj",
    "lint": "jja cls && eslint . --fix",
    "beautify": "jja cls && prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.0.1",
    "@vvi/check-version": "^1.1.1",
    "@vvi/command": "^4.0.0",
    "@vvi/rollup-external": "^1.2.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "gvv": "^1.0.1",
    "jja": "^2.5.1",
    "pjj": "^1.0.6",
    "pnpm": "^11.9.0",
    "prettier": "^3.9.1",
    "qqi": "^1.0.0",
    "rollup": "^4.62.2",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vjj": "^1.0.13"
  },
  "dependencies": {
    "@vvi/copy-text": "^1.1.2",
    "@vvi/is": "^2.0.5",
    "@vvi/log": "^1.1.5",
    "@vvi/node": "^5.0.0",
    "@vvi/pen": "^3.0.2"
  }
